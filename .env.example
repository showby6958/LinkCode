# ─────────────────────────────────────────────────────────────
#  LinkCode 환경변수 템플릿 — 이 파일을 .env 로 복사해 값을 채운다.
#    cp .env.example .env
#  인프라 호스트/포트/URI 는 컨테이너 표준값이라 그대로 두면 되고,
#  *_SECRET / *_PASSWORD / *_CLIENT_* / SLACK_* 만 실제 값으로 교체한다.
# ─────────────────────────────────────────────────────────────

# ── MySQL ──
DB_HOST=mysql
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=change-me
# mysql 컨테이너 root 비밀번호 (DB_PASSWORD 와 동일하게)
MYSQL_ROOT_PASSWORD=change-me

# ── Kafka (컨테이너 내부 INTERNAL 리스너) ──
KAFKA_BOOTSTRAP=kafka:19092

# ── Redis ──
REDIS_HOST=redis
REDIS_PORT=6379

# ── JWT (게이트웨이·모든 서비스가 동일 값 공유 필수) ──
JWT_SECRET=replace-with-a-long-random-256bit-secret

# ── OAuth (auth-service) ──
# OAUTH_REDIRECT_BASE 는 브라우저가 돌아올 외부 주소(게이트웨이). 운영은 https://내도메인.
# 이 값 + /login/oauth2/code/{google|naver} 를 각 콘솔의 승인된 리디렉션 URI에 등록해야 한다.
OAUTH_REDIRECT_BASE=http://localhost:8080
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret
SYSTEM_ADMIN_EMAIL=admin@example.com

# ── Gateway 라우팅 / CORS ──
AUTH_URI=http://auth-service:8081
INTERVIEW_URI=http://interview-service:8083
GATEWAY_JWKS_URI=http://auth-service:8081/oauth/.well-known/jwks.json
# 프론트 주소. 쉼표로 여러 개 지정 가능.
CORS_ORIGINS=http://localhost:3000

# ── chat-consumer (Slack 알림) ──
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXXX/YYYY/ZZZZ
